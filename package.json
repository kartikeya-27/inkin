{
  "name": "@inkin/core",
  "version": "0.1.0",
  "description": "Editable React diagrams from a typed schema. v0.1.0 ships the schema kernel only via the `@inkin/core/schema` subpath — zod types, parse(), dagre layout, JSON Schema export for AI tool-use. The React `<DiagramStudio>` component is added at the root entry in 0.2.0; the schema subpath remains stable forever.",
  "license": "MIT",
  "author": "kartikeya27",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kartikeya-27/inkin.git"
  },
  "type": "module",
  "engines": {
    "node": "^22.18.0 || >=24.0.0"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "require": "./dist/schema/index.cjs"
    },
    "./diagram.schema.json": "./dist/schema/diagram.schema.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown && node scripts/emit-json-schema.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "size": "size-limit",
    "attw": "pnpm dlx @arethetypeswrong/cli --pack",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm size",
    "prepublishOnly": "pnpm verify"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@types/node": "^22.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "size-limit": "^11.1.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "diagram",
    "schema",
    "zod",
    "react",
    "xyflow",
    "mermaid",
    "graph",
    "editable",
    "ai",
    "json-schema",
    "state-machine",
    "architecture"
  ]
}
