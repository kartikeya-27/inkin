{
  "name": "@inkin/core",
  "version": "0.3.0",
  "description": "Editable React diagrams from a typed schema. v0.3.0 adds in-place editing to <DiagramStudio>: drag, drag-to-connect, Delete-key cascade removal, double-click inline label editing, keyboard a11y. Supply `onChange` to opt in; omit it for the 0.2.0 read-only experience. The framework-agnostic schema kernel remains at the @inkin/core/schema subpath. Inspector / Palette chrome lands in 0.4.0.",
  "license": "MIT",
  "author": "kartikeya27",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kartikeya-27/inkin.git"
  },
  "type": "module",
  "engines": {
    "node": "^22.18.0 || >=24.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "require": "./dist/schema/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./diagram.schema.json": "./dist/schema/diagram.schema.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown && node scripts/emit-json-schema.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "size": "size-limit",
    "attw": "pnpm dlx @arethetypeswrong/cli --pack",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm size",
    "prepublishOnly": "pnpm verify",
    "examples": "pnpm --filter examples dev"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.0",
    "@xyflow/react": "^12.0.0",
    "html-to-image": "^1.11.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@playwright/test": "^1.60.0",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@tsdown/css": "^0.22.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^11.1.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "diagram",
    "react",
    "react-component",
    "schema",
    "zod",
    "xyflow",
    "react-flow",
    "mermaid",
    "graph",
    "editable",
    "ai",
    "json-schema",
    "state-machine",
    "architecture"
  ]
}
